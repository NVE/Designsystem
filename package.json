{
  "name": "nve-designsystem",
  "description": "Designsystem for NVE",
  "author": {
    "name": "NVE",
    "email": "nve@nve.no"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NVE/Designsystem"
  },
  "license": "MIT",
  "homepage": "https://github.com/NVE/Designsystem/",
  "version": "4.4.0",
  "customElements": "dist/custom-elements.json",
  "exports": {
    ".": {
      "import": "./nve-designsystem.js",
      "types": "./nve-designsystem.d.ts"
    },
    "./dist/custom-elements.json": "./custom-elements.json",
    "./dist/vscode.html-custom-data.json": "./vscode.html-custom-data.json",
    "./dist/vscode.css-custom-data.json": "./vscode.css-custom-data.json",
    "./components/*": "./components/*",
    "./registerIcons/*": "./registerIcons/*",
    "./css/*": "./css/*",
    "./fonts/*": "./fonts/*"
  },
  "type": "module",
  "types": "nve-designsystem.d.ts",
  "scripts": {
    "add-component": "node scripts/createNewComponent.js",
    "dev": "node scripts/buildForDev.js && pnpm --dir doc-site run dev",
    "doc:build": "pnpm --dir doc-site run build",
    "doc:preview": "pnpm --dir doc-site run preview",
    "pack": "node scripts/prepublish.js pack",
    "publish": "node scripts/prepublish.js publish",
    "build": "node scripts/build.js",
    "build:dev": "node scripts/build.js dev",
    "build:doc": "node scripts/build.js && pnpm --dir doc-site run build",
    "link": "node scripts/npmLink.js",
    "preview": "vite preview",
    "lint": "eslint \"**/*.{js,ts,vue}\"",
    "manifest": "node scripts/createCustomManifest.js",
    "tokenbuild": "node transformTokens/transform.js && node scripts/groupDeviceFilesToBrandFiles.js && node scripts/updateCssTokensInDocs.js",
    "prepare": "husky",
    "test:ui": "vitest --ui",
    "test": "vitest"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "^2.20.1",
    "fontfaceobserver": "^2.3.0",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@tokens-studio/sd-transforms": "^2.0.1",
    "@types/fontfaceobserver": "^2.1.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@wc-toolkit/cem-inheritance": "^1.2.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "command-line-args": "^6.0.2",
    "comment-parser": "^1.4.7",
    "commitizen": "^4.3.2",
    "cpy": "^13.2.2",
    "cpy-cli": "^7.0.0",
    "custom-element-jet-brains-integration": "^1.7.0",
    "custom-element-vs-code-integration": "^1.5.0",
    "custom-element-vuejs-integration": "^1.4.0",
    "custom-elements-manifest": "^2.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-vue": "^10.9.2",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "ora": "^9.4.0",
    "pascal-case": "^4.0.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semantic-release": "^25.0.5",
    "style-dictionary": "^5.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "minimist": ">=1.2.6",
    "lodash": ">=4.18.0",
    "tmp": ">=0.2.4",
    "@vue/eslint-config-typescript": {
      "@typescript-eslint/utils": "8.59.3",
      "typescript-eslint": "8.59.3"
    },
    "koa": "2.16.4"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
